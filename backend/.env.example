# ============================================================
# DeckStudio Backend — Environment Variables Example
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ─────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────

# Environment: development | staging | production
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# API title shown in /docs
APP_TITLE=DeckStudio API

# API version string
APP_VERSION=0.1.0

# CORS: comma-separated list of allowed origins
# Example: http://localhost:3000,https://app.deckstudio.io
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────

# Host to bind uvicorn
HOST=0.0.0.0

# Port to bind uvicorn
PORT=8000

# Number of uvicorn worker processes (production)
WORKERS=1

# ─────────────────────────────────────────
# LLM PROVIDERS
# ─────────────────────────────────────────

# Primary LLM provider: anthropic | openai
LLM_PROVIDER=anthropic

# Anthropic API key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Anthropic model name
# Recommended: claude-3-5-sonnet-20241022
ANTHROPIC_MODEL=claude-opus-4-5

# OpenAI API key (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# OpenAI model name
OPENAI_MODEL=gpt-4o

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.3

# Maximum tokens for LLM responses
LLM_MAX_TOKENS=8192

# LLM request timeout in seconds
LLM_TIMEOUT_SECONDS=120

# ─────────────────────────────────────────
# AGENT PIPELINE
# ─────────────────────────────────────────

# Maximum number of LangGraph recursion steps
LANGGRAPH_MAX_STEPS=50

# Enable human-in-the-loop checkpoints: true | false
CHECKPOINT_ENABLED=true

# Checkpoint modes: outline | slides | review | all
# Comma-separated list of stages where human approval is required
CHECKPOINT_STAGES=outline,review

# Session TTL in seconds (default: 3600 = 1 hour)
SESSION_TTL_SECONDS=3600

# ─────────────────────────────────────────
# FILE PROCESSING
# ─────────────────────────────────────────

# Maximum file upload size in MB
MAX_UPLOAD_SIZE_MB=50

# Allowed upload MIME types (comma-separated)
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,text/markdown

# Temporary directory for uploaded files (default: system temp)
# UPLOAD_TEMP_DIR=/tmp/deckstudio

# ─────────────────────────────────────────
# STORAGE (optional, for persistent sessions)
# ─────────────────────────────────────────

# Storage backend: memory | sqlite | postgres
STORAGE_BACKEND=memory

# SQLite database path (when STORAGE_BACKEND=sqlite)
# SQLITE_PATH=data/deckstudio.db

# PostgreSQL DSN (when STORAGE_BACKEND=postgres)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/deckstudio

# ─────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────

# Secret key for signing session tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# API key authentication: set to require an API key on all routes
# Leave empty to disable API key auth (development only)
API_KEY=

# ─────────────────────────────────────────
# OBSERVABILITY (optional)
# ─────────────────────────────────────────

# Enable LangSmith tracing: true | false
LANGSMITH_TRACING=false

# LangSmith API key (required when LANGSMITH_TRACING=true)
# LANGSMITH_API_KEY=ls__...

# LangSmith project name
# LANGSMITH_PROJECT=deckstudio

# Enable structured JSON logging: true | false
JSON_LOGS=false
