# /opt/deckstudio/backend/.env — Production environment
# Copy this file to /opt/deckstudio/backend/.env and fill in the values.
# Never commit this file to version control.

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=8001
APP_LOG_LEVEL=info

# ── CORS — frontend origin (nginx serves on 443) ──────────────────────────────
CORS_ORIGINS=https://deckstudio.karlekar.cloud

# ── Storage ───────────────────────────────────────────────────────────────────
EXPORT_DIR=/opt/deckstudio/data/exports
SESSION_TTL_MINUTES=120

# ── DeepAgents checkpointing ─────────────────────────────────────────────────
DEEPAGENTS_CHECKPOINT_DB=/opt/deckstudio/data/deckstudio_checkpoints.db
